{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vergil-ver2-argb-recolor.config.schema.json",
  "title": "剑魂 Vergil 主题 Ver2 ARGB 同格式调色配置",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "themeId",
    "sourceNpk",
    "output",
    "expectations",
    "allowedImgPaths",
    "excludedImgPaths",
    "excludedFrameKeys"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "themeId": {
      "const": "weaponmaster-vergil-dark-blue"
    },
    "sourceNpk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "length"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "length": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "componentNpkPath",
        "buildSummaryPath"
      ],
      "properties": {
        "componentNpkPath": {
          "type": "string",
          "pattern": "\\.[Nn][Pp][Kk]$"
        },
        "buildSummaryPath": {
          "type": "string",
          "pattern": "(^|[/\\\\])build-summary\\.[Jj][Ss][Oo][Nn]$"
        }
      }
    },
    "expectations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "albumCount",
        "frameCount"
      ],
      "properties": {
        "albumCount": {
          "type": "integer",
          "minimum": 1
        },
        "frameCount": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "allowedImgPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[^#]+\\.[Ii][Mm][Gg]$"
      }
    },
    "excludedImgPaths": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[^#]+\\.[Ii][Mm][Gg]$"
      },
      "description": "已核验但不应进入组件的 IMG；必须存在且不得与 allowedImgPaths 重叠。"
    },
    "excludedFrameKeys": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[^#]+\\.[Ii][Mm][Gg]#[0-9]+$"
      },
      "description": "必须显式存在；没有排除帧时使用空数组。"
    }
  }
}
