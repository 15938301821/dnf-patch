{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vergil-ver5-dds-recolor.config.schema.json",
  "title": "剑魂 Vergil 主题 Ver5 DDS 结构保持调色配置",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "themeId",
    "sourceNpk",
    "output",
    "allowedImgPaths",
    "excludedFrameKeys"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": 1
    },
    "themeId": {
      "const": "weaponmaster-vergil-dark-blue"
    },
    "sourceNpk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "length": {
          "type": "integer",
          "minimum": 0,
          "description": "0 或省略表示只按 SHA-256 固化；正数时同时校验文件长度。"
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "componentNpkPath",
        "buildSummaryPath"
      ],
      "properties": {
        "componentNpkPath": {
          "type": "string",
          "pattern": "\\.[Nn][Pp][Kk]$"
        },
        "buildSummaryPath": {
          "type": "string",
          "pattern": "(^|[/\\\\])build-summary\\.[Jj][Ss][Oo][Nn]$"
        }
      }
    },
    "allowedImgPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[^#]+\\.[Ii][Mm][Gg]$"
      }
    },
    "excludedFrameKeys": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[^#]+\\.[Ii][Mm][Gg]#[0-9]+$"
      },
      "description": "必须显式存在；没有排除帧时使用空数组。共享 Texture 任一引用命中排除键时整组不改。"
    }
  }
}
