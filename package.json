{
  "name": "dnf-patch-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Browser and Electron frontend for the DNF patch service",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:web": "vite --config vite.config.ts",
    "dev:desktop": "electron-vite dev",
    "build": "npm run build:web && npm run build:desktop",
    "build:web": "vite build --config vite.config.ts",
    "build:desktop": "electron-vite build",
    "preview": "vite preview --config vite.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint electron renderer tests electron.vite.config.ts vite.config.ts playwright.config.ts vitest.config.ts eslint.config.js",
    "test:unit": "vitest run",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "format": "prettier --write \"electron/**/*.ts\" \"renderer/**/*.{ts,tsx,scss,css,html}\" \"tests/**/*.{ts,tsx}\" \"electron.vite.config.ts\" \"vite.config.ts\" \"playwright.config.ts\" \"vitest.config.ts\" \"eslint.config.js\" \"tsconfig*.json\" \"package.json\" \"AGENTS.md\" \"README.md\" \".prettierrc.json\" \".github/instructions/**/*.md\" \".vscode/**/*.{json,md}\"",
    "format:check": "prettier --check \"electron/**/*.ts\" \"renderer/**/*.{ts,tsx,scss,css,html}\" \"tests/**/*.{ts,tsx}\" \"electron.vite.config.ts\" \"vite.config.ts\" \"playwright.config.ts\" \"vitest.config.ts\" \"eslint.config.js\" \"tsconfig*.json\" \"package.json\" \"AGENTS.md\" \"README.md\" \".prettierrc.json\" \".github/instructions/**/*.md\" \".vscode/**/*.{json,md}\"",
    "gate:static": "npm run format:check && npm run typecheck && npm run lint && npm run test:unit",
    "gate:project": "npm run gate:static && npm run test:e2e"
  },
  "dependencies": {
    "antd": "^6.5.1",
    "axios": "^1.18.1",
    "axios-mock-adapter": "^2.1.0",
    "lucide-react": "1.25.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "40.10.2",
    "electron-vite": "5.0.0",
    "eslint": "10.0.1",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.64.0",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  }
}
