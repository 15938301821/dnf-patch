{
  "name": "dnf-patch-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Auditable desktop entrypoint for the DNF patch agentic pipeline",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "agent": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "test:unit": "vitest run --exclude tests/electron.spec.ts",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test tests/electron.spec.ts",
    "validate:project": "tsx scripts/validate-project.ts",
    "gate:static": "npm run typecheck && npm run lint && npm run test:unit && npm run validate:project",
    "gate:project": "npm run gate:static && npm run test:e2e"
  },
  "dependencies": {
    "archiver": "8.0.0",
    "lucide-react": "1.25.0",
    "openai": "6.48.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "yauzl": "3.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/archiver": "8.0.0",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/yauzl": "3.4.0",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "40.10.2",
    "electron-vite": "5.0.0",
    "eslint": "10.0.1",
    "tsx": "4.23.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.64.0",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  }
}
