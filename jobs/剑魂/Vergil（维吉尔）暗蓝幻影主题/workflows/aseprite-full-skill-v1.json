{
  "schemaVersion": 1,
  "workflowId": "weaponmaster.vergil.aseprite-full-skill-v1",
  "description": "Offline Aseprite activity aggregation, final validation, human review, and release closure.",
  "themeRoot": "剑魂/Vergil（维吉尔）暗蓝幻影主题",
  "runRoot": "剑魂/Vergil（维吉尔）暗蓝幻影主题/automation-runs",
  "policy": {
    "executeRequiresExplicitSwitch": true,
    "network": "forbidden",
    "deployment": "forbidden",
    "processOperations": "forbidden",
    "imagePacks2Write": "forbidden",
    "requireFreshRunDirectory": true,
    "allowedWriteRoots": ["{{runDirectory}}"],
    "allowedAtomicReplacePaths": ["剑魂/manifest.json"],
    "recovery": {
      "requireWorkflowHash": true,
      "requireRegistryHash": true,
      "requireRunnerHash": true,
      "requireAdapterScriptHash": true,
      "requireParameterHash": true,
      "requireInputSnapshots": true,
      "requireOutputSnapshots": true
    }
  },
  "steps": [
    {
      "id": "powershell-source-gate",
      "adapter": "powershell-source-gate",
      "mode": "read-only",
      "dependsOn": [],
      "parameters": {
        "Path": "{{repositoryRoot}}"
      },
      "inputs": [
        {
          "id": "repository-rules",
          "path": "AGENTS.md",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        },
        {
          "id": "workflow-definition",
          "path": "剑魂/Vergil（维吉尔）暗蓝幻影主题/workflows/aseprite-full-skill-v1.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        }
      ],
      "success": {
        "all": [
          { "path": "status", "operator": "equals", "value": "passed" },
          { "path": "issueCount", "operator": "equals", "value": 0 },
          { "path": "fileCount", "operator": "greaterThan", "value": 0 }
        ]
      }
    },
    {
      "id": "local-toolchain-gate",
      "adapter": "local-toolchain-gate",
      "mode": "read-only",
      "dependsOn": ["powershell-source-gate"],
      "parameters": {
        "RequireAseprite": true
      },
      "inputs": [
        {
          "id": "local-settings",
          "path": ".dnf-patch.local.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        }
      ],
      "success": {
        "all": [
          { "path": "status", "operator": "equals", "value": "passed" },
          { "path": "source.readOnlyPolicy", "operator": "isTrue" },
          {
            "path": "source.deploymentTargetConfigured",
            "operator": "isFalse"
          },
          { "path": "aseprite.available", "operator": "isTrue" },
          {
            "path": "aseprite.apiCapability.status",
            "operator": "equals",
            "value": "passed"
          },
          {
            "path": "systemPrerequisites.x86PowerShellAvailable",
            "operator": "isTrue"
          },
          {
            "path": "systemPrerequisites.dotNetFrameworkCompilerAvailable",
            "operator": "isTrue"
          }
        ]
      }
    },
    {
      "id": "migration-readiness-gate",
      "adapter": "vergil-aseprite-migration-gate",
      "mode": "read-only",
      "dependsOn": ["local-toolchain-gate"],
      "parameters": {
        "ResourcePlanPath": "{{repositoryRoot}}/剑魂/Vergil（维吉尔）暗蓝幻影主题/configs/full-skill-v1/resource-plan-v4.json",
        "RepoRoot": "{{repositoryRoot}}"
      },
      "inputs": [
        {
          "id": "activity-resource-plan",
          "path": "剑魂/Vergil（维吉尔）暗蓝幻影主题/configs/full-skill-v1/resource-plan-v4.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        }
      ],
      "success": {
        "all": [
          { "path": "status", "operator": "equals", "value": "passed" },
          {
            "path": "state",
            "operator": "equals",
            "value": "ready-for-aggregation"
          },
          { "path": "readyForAggregation", "operator": "isTrue" },
          { "path": "fullSkillCoverageProven", "operator": "isFalse" },
          {
            "path": "components.provenanceIssueCount",
            "operator": "equals",
            "value": 0
          },
          {
            "path": "deployment",
            "operator": "equals",
            "value": "not-authorized-not-performed"
          }
        ]
      }
    },
    {
      "id": "aggregate-package",
      "adapter": "vergil-aseprite-aggregate",
      "mode": "workspace-write",
      "dependsOn": ["migration-readiness-gate"],
      "parameters": {
        "ResourcePlanPath": "{{repositoryRoot}}/剑魂/Vergil（维吉尔）暗蓝幻影主题/configs/full-skill-v1/resource-plan-v4.json",
        "OutputNpk": "{{runDirectory}}/artifact/weaponmaster-vergil-dark-blue-aseprite-{{runId}}-v1.NPK",
        "PackageSummaryPath": "{{runDirectory}}/package/package-summary-aseprite-{{runId}}-v1.json",
        "RepoRoot": "{{repositoryRoot}}"
      },
      "inputs": [
        {
          "id": "activity-resource-plan",
          "path": "剑魂/Vergil（维吉尔）暗蓝幻影主题/configs/full-skill-v1/resource-plan-v4.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        }
      ],
      "outputs": [
        {
          "id": "final-npk",
          "path": "{{runDirectory}}/artifact/weaponmaster-vergil-dark-blue-aseprite-{{runId}}-v1.NPK",
          "required": true,
          "snapshot": "sha256",
          "kind": "file",
          "disposition": "create-new"
        },
        {
          "id": "package-summary",
          "path": "{{runDirectory}}/package/package-summary-aseprite-{{runId}}-v1.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file",
          "disposition": "create-new"
        }
      ],
      "success": {
        "all": [
          { "path": "status", "operator": "equals", "value": "passed" },
          {
            "path": "state",
            "operator": "equals",
            "value": "aggregated-awaiting-final-validation"
          },
          { "path": "readiness.readyForAggregation", "operator": "isTrue" },
          {
            "path": "readiness.fullSkillCoverageProven",
            "operator": "isFalse"
          },
          {
            "path": "counts.finalImgCount",
            "operator": "equals",
            "value": 418
          },
          {
            "path": "counts.sourceNpkCount",
            "operator": "equals",
            "value": 32
          },
          { "path": "deployment.performed", "operator": "isFalse" }
        ]
      }
    },
    {
      "id": "final-validation",
      "adapter": "vergil-aseprite-final-validation",
      "mode": "workspace-write",
      "dependsOn": ["aggregate-package"],
      "parameters": {
        "ResourcePlanPath": "{{repositoryRoot}}/剑魂/Vergil（维吉尔）暗蓝幻影主题/configs/full-skill-v1/resource-plan-v4.json",
        "FinalNpk": "{{runDirectory}}/artifact/weaponmaster-vergil-dark-blue-aseprite-{{runId}}-v1.NPK",
        "PackageSummaryPath": "{{runDirectory}}/package/package-summary-aseprite-{{runId}}-v1.json",
        "OutputDirectory": "{{runDirectory}}/final-validation-aseprite-{{runId}}-v1",
        "RepoRoot": "{{repositoryRoot}}"
      },
      "inputs": [
        {
          "id": "final-npk",
          "path": "{{runDirectory}}/artifact/weaponmaster-vergil-dark-blue-aseprite-{{runId}}-v1.NPK",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        },
        {
          "id": "package-summary",
          "path": "{{runDirectory}}/package/package-summary-aseprite-{{runId}}-v1.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        }
      ],
      "outputs": [
        {
          "id": "final-validation-directory",
          "path": "{{runDirectory}}/final-validation-aseprite-{{runId}}-v1",
          "required": true,
          "snapshot": "sha256",
          "kind": "directory",
          "disposition": "create-new"
        }
      ],
      "success": {
        "all": [
          { "path": "status", "operator": "equals", "value": "passed" },
          { "path": "eligibleForReleaseMetadata", "operator": "isTrue" },
          { "path": "fullSkillCoverageProven", "operator": "isFalse" },
          { "path": "imgCount", "operator": "equals", "value": 418 },
          { "path": "frameCount", "operator": "equals", "value": 3822 },
          { "path": "sourceNpkCount", "operator": "equals", "value": 32 },
          { "path": "deployed", "operator": "isFalse" }
        ]
      }
    },
    {
      "id": "manual-review-template",
      "adapter": "final-manual-review-template",
      "mode": "workspace-write",
      "dependsOn": ["final-validation"],
      "parameters": {
        "FinalSummaryPath": "{{runDirectory}}/final-validation-aseprite-{{runId}}-v1/final-validation-summary.json",
        "OutputPath": "{{runDirectory}}/manual-review-template.json",
        "RepoRoot": "{{repositoryRoot}}"
      },
      "inputs": [
        {
          "id": "final-summary",
          "path": "{{runDirectory}}/final-validation-aseprite-{{runId}}-v1/final-validation-summary.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        }
      ],
      "outputs": [
        {
          "id": "manual-review-template",
          "path": "{{runDirectory}}/manual-review-template.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file",
          "disposition": "create-new"
        }
      ],
      "success": {
        "all": [
          { "path": "status", "operator": "equals", "value": "passed" },
          {
            "path": "state",
            "operator": "equals",
            "value": "manual-review-template-created"
          },
          { "path": "approved", "operator": "isFalse" },
          {
            "path": "contactSheetCount",
            "operator": "greaterThan",
            "value": 0
          },
          { "path": "fullSkillCoverageProven", "operator": "isFalse" }
        ]
      }
    },
    {
      "id": "manual-review-gate",
      "adapter": "final-manual-review-gate",
      "mode": "read-only",
      "dependsOn": ["manual-review-template"],
      "parameters": {
        "FinalSummaryPath": "{{runDirectory}}/final-validation-aseprite-{{runId}}-v1/final-validation-summary.json",
        "ManualReviewPath": "{{runDirectory}}/manual-review.json",
        "MaxAgeHours": 168,
        "RepoRoot": "{{repositoryRoot}}"
      },
      "inputs": [
        {
          "id": "final-summary",
          "path": "{{runDirectory}}/final-validation-aseprite-{{runId}}-v1/final-validation-summary.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        },
        {
          "id": "manual-review",
          "path": "{{runDirectory}}/manual-review.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        }
      ],
      "approval": {
        "evidencePath": "{{runDirectory}}/manual-review.json",
        "statusPath": "approved",
        "approvedValue": true,
        "approvedAtPath": "approvedAtUtc",
        "maxAgeHours": 168
      },
      "success": {
        "all": [
          { "path": "status", "operator": "equals", "value": "passed" },
          { "path": "approved", "operator": "isTrue" },
          { "path": "finalSummaryBound", "operator": "isTrue" },
          { "path": "reviewedAllContactSheets", "operator": "isTrue" },
          { "path": "findingCount", "operator": "equals", "value": 0 },
          { "path": "fullSkillCoverageProven", "operator": "isFalse" },
          { "path": "targetClientCompatibilityProven", "operator": "isFalse" }
        ]
      }
    },
    {
      "id": "release-metadata-closure",
      "adapter": "release-metadata-close",
      "mode": "workspace-write",
      "dependsOn": ["manual-review-gate"],
      "parameters": {
        "FinalSummaryPath": "{{runDirectory}}/final-validation-aseprite-{{runId}}-v1/final-validation-summary.json",
        "ManualReviewPath": "{{runDirectory}}/manual-review.json",
        "ProfessionManifestPath": "{{repositoryRoot}}/剑魂/manifest.json",
        "ReleaseReportPath": "{{runDirectory}}/release-aseprite-{{runId}}-v1.json",
        "TransactionReceiptPath": "{{runDirectory}}/release-transaction-aseprite-{{runId}}-v1.json",
        "ReleaseId": "weaponmaster.vergil.aseprite-{{runId}}-v1",
        "ManualReviewMaxAgeHours": 168,
        "RepoRoot": "{{repositoryRoot}}"
      },
      "inputs": [
        {
          "id": "profession-manifest-before-closure",
          "path": "剑魂/manifest.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        },
        {
          "id": "final-summary",
          "path": "{{runDirectory}}/final-validation-aseprite-{{runId}}-v1/final-validation-summary.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        },
        {
          "id": "manual-review",
          "path": "{{runDirectory}}/manual-review.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        }
      ],
      "outputs": [
        {
          "id": "release-report",
          "path": "{{runDirectory}}/release-aseprite-{{runId}}-v1.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file",
          "disposition": "resume-reconcile"
        },
        {
          "id": "profession-manifest-after-closure",
          "path": "剑魂/manifest.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file",
          "disposition": "atomic-replace"
        },
        {
          "id": "release-transaction-receipt",
          "path": "{{runDirectory}}/release-transaction-aseprite-{{runId}}-v1.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file",
          "disposition": "resume-reconcile"
        }
      ],
      "success": {
        "all": [
          { "path": "status", "operator": "equals", "value": "passed" },
          {
            "path": "state",
            "operator": "equals",
            "value": "offline-release-closed-client-pending"
          },
          { "path": "releaseClosure", "operator": "equals", "value": "passed" },
          {
            "path": "transaction.status",
            "operator": "equals",
            "value": "committed"
          },
          {
            "path": "fullSkillCoverageProvenAtValidationStart",
            "operator": "isFalse"
          },
          {
            "path": "fullSkillCoverageProvenAfterMetadataClosure",
            "operator": "isTrue"
          },
          { "path": "targetClientCompatibilityProven", "operator": "isFalse" },
          { "path": "deployment.performed", "operator": "isFalse" }
        ]
      }
    },
    {
      "id": "release-closure-gate",
      "adapter": "release-closure-gate",
      "mode": "read-only",
      "dependsOn": ["release-metadata-closure"],
      "parameters": {
        "ProfessionManifestPath": "{{repositoryRoot}}/剑魂/manifest.json",
        "ReleaseReportPath": "{{runDirectory}}/release-aseprite-{{runId}}-v1.json",
        "RepoRoot": "{{repositoryRoot}}"
      },
      "inputs": [
        {
          "id": "profession-manifest-after-closure",
          "path": "剑魂/manifest.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        },
        {
          "id": "release-report",
          "path": "{{runDirectory}}/release-aseprite-{{runId}}-v1.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        }
      ],
      "success": {
        "all": [
          { "path": "status", "operator": "equals", "value": "passed" },
          {
            "path": "resourcePlanValidation",
            "operator": "equals",
            "value": "passed-live-and-snapshot"
          },
          {
            "path": "independentIndex",
            "operator": "equals",
            "value": "passed-live-and-snapshot"
          },
          {
            "path": "fullSkillCoverageProvenAtValidationStart",
            "operator": "isFalse"
          },
          {
            "path": "fullSkillCoverageProvenAfterMetadataClosure",
            "operator": "isTrue"
          },
          { "path": "targetClientCompatibilityProven", "operator": "isFalse" },
          {
            "path": "deployment",
            "operator": "equals",
            "value": "not-authorized-not-performed"
          }
        ]
      }
    },
    {
      "id": "project-gate",
      "adapter": "project-gate",
      "mode": "read-only",
      "dependsOn": ["release-closure-gate"],
      "parameters": {},
      "inputs": [
        {
          "id": "profession-manifest-final",
          "path": "剑魂/manifest.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        },
        {
          "id": "release-report",
          "path": "{{runDirectory}}/release-aseprite-{{runId}}-v1.json",
          "required": true,
          "snapshot": "sha256",
          "kind": "file"
        }
      ],
      "success": {
        "all": [
          { "path": "status", "operator": "equals", "value": "passed" },
          {
            "path": "workflowGateCount",
            "operator": "greaterThan",
            "value": 0
          },
          {
            "path": "unmanagedTopLevelDirectoryCount",
            "operator": "equals",
            "value": 0
          },
          { "path": "gitDiffCheck", "operator": "equals", "value": "passed" }
        ]
      }
    }
  ]
}
