{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dnf-patch.local/schemas/step-result.schema.json",
  "title": "DNF patch automation step result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "workflowId",
    "runId",
    "stepId",
    "adapter",
    "state",
    "startedAtUtc",
    "finishedAtUtc",
    "bindings",
    "inputs",
    "outputs",
    "successPredicates",
    "deployment"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "workflowId": { "type": "string" },
    "runId": { "type": "string" },
    "stepId": { "type": "string" },
    "adapter": { "type": "string" },
    "state": {
      "enum": ["passed", "blocked", "failed", "reused"]
    },
    "startedAtUtc": { "type": "string", "format": "date-time" },
    "finishedAtUtc": { "type": "string", "format": "date-time" },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflowSha256",
        "registrySha256",
        "runnerSha256",
        "adapterScriptSha256",
        "parameterSha256"
      ],
      "properties": {
        "workflowSha256": { "$ref": "#/$defs/sha256" },
        "registrySha256": { "$ref": "#/$defs/sha256" },
        "runnerSha256": { "$ref": "#/$defs/sha256" },
        "adapterScriptSha256": { "$ref": "#/$defs/sha256" },
        "parameterSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/snapshot" }
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/snapshot" }
    },
    "successPredicates": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["path", "operator", "passed"],
        "properties": {
          "path": { "type": "string" },
          "operator": { "type": "string" },
          "passed": { "type": "boolean" }
        }
      }
    },
    "adapterResult": {},
    "error": {
      "type": ["string", "null"]
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authorized",
        "performed",
        "imagePacks2Write",
        "processOperation"
      ],
      "properties": {
        "authorized": { "const": false },
        "performed": { "const": false },
        "imagePacks2Write": { "const": false },
        "processOperation": { "const": false }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9A-F]{64}$"
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path", "kind", "length", "sha256"],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" },
        "kind": { "enum": ["file", "directory"] },
        "length": { "type": "integer", "minimum": 0 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
