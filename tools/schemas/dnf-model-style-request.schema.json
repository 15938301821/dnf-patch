{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dnf-patch.local/schemas/dnf-model-style-request.schema.json",
  "title": "DNF model generated style request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "professionPath",
    "themePath",
    "promptBinding",
    "styleIntent"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "professionPath": { "$ref": "#/$defs/repositoryRelativePath" },
    "themePath": { "$ref": "#/$defs/repositoryRelativePath" },
    "promptBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "themeAgentPath",
        "professionPromptPath",
        "themePromptPath",
        "uiFrameGeometryPolicy"
      ],
      "properties": {
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "themeAgentPath": { "$ref": "#/$defs/repositoryRelativePath" },
        "professionPromptPath": { "$ref": "#/$defs/repositoryRelativePath" },
        "themePromptPath": { "$ref": "#/$defs/repositoryRelativePath" },
        "uiFrameGeometryPolicy": {
          "const": "strict-preserve-source-frame-position-size"
        }
      }
    },
    "styleIntent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["palette", "operations"],
      "properties": {
        "palette": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          }
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type"],
            "properties": {
              "type": {
                "enum": [
                  "palette-map",
                  "rim-light",
                  "particle-trail",
                  "spatial-crack",
                  "blade-core",
                  "alpha-preserve"
                ]
              },
              "target": { "type": "string", "minLength": 1 },
              "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
              "colorStops": {
                "type": "array",
                "items": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
              },
              "intensity": { "type": "number", "minimum": 0, "maximum": 1 },
              "density": { "type": "number", "minimum": 0, "maximum": 1 },
              "direction": { "type": "string", "minLength": 1 },
              "blend": {
                "enum": [
                  "source-preserving",
                  "additive-reference-only",
                  "normal-reference-only"
                ]
              },
              "notes": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "repositoryRelativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\:]+$"
    }
  }
}
