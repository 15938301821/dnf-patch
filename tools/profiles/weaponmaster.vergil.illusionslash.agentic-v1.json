        "aseprite.available=true",
        "systemPrerequisites.x86PowerShellAvailable=true"
      ]
    },
    {
      "id": "export-source",
      "toolId": "export-vergil-illusionslash-source",
      "phase": "inventory",
      "dependsOn": ["toolchain-gate"],
      "mode": "workspace-write",
      "arguments": {
