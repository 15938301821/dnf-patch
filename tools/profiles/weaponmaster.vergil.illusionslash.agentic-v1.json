        "RunId": "{{runId}}",
        "OutputNpkPath": "{{outputNpkPath}}",
        "BuildSummaryPath": "{{buildSummaryPath}}",
        "ValidationDirectory": "剑魂/Vergil（维吉尔）暗蓝幻影主题/validation/{{runId}}/build-illusionslash"
      },
      "expectedOutputs": [
