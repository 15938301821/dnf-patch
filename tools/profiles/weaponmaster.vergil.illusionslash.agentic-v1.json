        "剑魂/Vergil（维吉尔）暗蓝幻影主题/frames/runtime/{{runId}}/illusionslash"
      ],
      "successPredicates": [
        "FrameCount>0",
        "model style plan applied",
        "Deployment=not-authorized-not-performed"
      ]
    },
    {
      "id": "build-and-validate",
      "toolId": "build-vergil-illusionslash-aseprite",
      "phase": "post-model",
      "dependsOn": ["render-aseprite"],
      "mode": "workspace-write",
      "arguments": {
